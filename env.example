# --- InfluxDB (existing) ---
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=admin12345
INFLUXDB_ORG=pms-org
INFLUXDB_BUCKET=sensor-data
INFLUXDB_TOKEN=replace-with-a-long-random-token

# --- PostgreSQL (Module 8 — user accounts, RBAC, audit log) ---
POSTGRES_USER=pms_user
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_DB=pms_auth

# --- JWT (Module 8) ---
# Generate a real one with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-a-64-char-random-hex-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_MIN_LENGTH=8

# --- SMTP (Module 8 — registration confirmation + forgot password emails) ---
# Leave blank during development: emails will be logged to the backend's
# console instead of sent, so you can copy the verification/reset link
# straight from `docker compose logs backend` for demos.
# For a real defense demo, a free Gmail "App Password" works well:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=youraddress@gmail.com
#   SMTP_PASSWORD=<16-character app password, NOT your normal Gmail password>
#   SMTP_FROM=youraddress@gmail.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@predictive-maintenance.local

# --- Frontend (Module 8 — used to build email links) ---
FRONTEND_URL=http://localhost:3000
