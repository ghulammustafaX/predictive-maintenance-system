# ═══════════════════════════════════════════════════════════════════
# PMS Environment Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
# ═══════════════════════════════════════════════════════════════════

# InfluxDB Configuration
INFLUXDB_USERNAME=your_influx_username
INFLUXDB_PASSWORD=your_secure_password
INFLUXDB_ORG=your-org-name
INFLUXDB_BUCKET=sensor-data
INFLUXDB_TOKEN=your_influxdb_token_here

# Kafka Configuration
KAFKA_BROKER=localhost:9092
SENSOR_TOPIC=sensor-telemetry
BEARING_TOPIC=bearing-telemetry

# PostgreSQL Database
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_secure_db_password
POSTGRES_DB=pms_database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# JWT Authentication - Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=generate_a_random_256_bit_hex_string_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30

# SMTP Email Configuration (for password reset, verification emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM=your-email@gmail.com
SMTP_TLS=true

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Application Settings
APP_ENV=development
DEBUG=true
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5500

# Security
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
CORS_CREDENTIALS=true

# Monitoring & Logging
LOG_LEVEL=INFO
SENTRY_DSN=your_sentry_dsn_if_using
